{% macro backtest_icon(ctx) -%}
{%- if ctx and ctx.get('effective') -%}
✅
{%- elif ctx and ctx.get('status') in ['error', 'failed'] -%}
❌
{%- elif ctx -%}
⚠️
{%- else -%}
⚪
{%- endif -%}
{%- endmacro %}

{% macro render_backtests(analysis_backtests, quant_backtests, compact=False, heading='##') %}
{% if analysis_backtests or quant_backtests %}
{% if compact %}
**📈 回测验证**
{% if analysis_backtests %}
AI历史: {{ backtest_icon(analysis_backtests) }} {{ analysis_backtests.conclusion }}
{% endif %}
{% if quant_backtests %}
量化策略: {{ backtest_icon(quant_backtests) }} {{ quant_backtests.conclusion }}
{% endif %}
{% else %}
{{ heading }} 📈 回测验证

{% if analysis_backtests %}
- **AI历史回测**：{{ backtest_icon(analysis_backtests) }} {{ analysis_backtests.conclusion }}
{% set overall = analysis_backtests.get('overall') or {} %}
{% if overall %}

| 样本 | 胜率 | 方向准确率 | 平均收益 |
|------|------|------------|----------|
| {{ overall.get('completed_count', 'N/A') }} | {{ '%.2f'|format(overall.get('win_rate_pct') or 0) }}% | {{ '%.2f'|format(overall.get('direction_accuracy_pct') or 0) }}% | {{ '%.2f'|format(overall.get('avg_return_pct') or 0) }}% |
{% endif %}
{% endif %}

{% if quant_backtests %}
- **量化策略回测**：{{ backtest_icon(quant_backtests) }} {{ quant_backtests.conclusion }}
{% if quant_backtests.items %}
- 策略：{{ quant_backtests.strategy }} | 区间：{{ quant_backtests.start_date }} 至 {{ quant_backtests.end_date }} | 成功：{{ quant_backtests.success }} | 失败：{{ quant_backtests.failed }}

| 股票 | 收益 | 基准 | 最大回撤 | 夏普 | 胜率 | 风险 |
|------|------|------|----------|------|------|------|
{% for bt in quant_backtests.top_by_sharpe[:5] %}
| {{ bt.symbol }} | {{ '%.2f'|format(bt.metrics.total_return_pct or 0) }}% | {{ '%.2f'|format(bt.metrics.benchmark_return_pct or 0) }}% | {{ '%.2f'|format(bt.metrics.max_drawdown_pct or 0) }}% | {{ '%.2f'|format(bt.metrics.sharpe_ratio or 0) }} | {{ '%.2f'|format(bt.metrics.win_rate_pct or 0) }}% | {{ bt.assessment.risk_level }} |
{% endfor %}
{% if quant_backtests.high_risk_items %}

**高风险提示**：{{ quant_backtests.high_risk_items|map(attribute='symbol')|join(', ') }}
{% endif %}
{% endif %}
{% endif %}

{% endif %}
{% endif %}
{% endmacro %}
